# ---------------------------------------------------------------------------
# VerifyPay — server-side secrets. Copy to .env.local and fill in real values.
# .env.local is git-ignored. These are read ONLY in server code (route
# handlers under src/app/api/*), never shipped to the browser. Do NOT add the
# NEXT_PUBLIC_ prefix to any secret.
# ---------------------------------------------------------------------------

# --- TNG Identity (verifiable-credentials verifier) ---
# Base URL is built as: https://<host>/products/web/<envHash>/verifier
TNG_IDENTITY_HOST=identity.products.teranode.group
TNG_IDENTITY_ENV_HASH=          # your environment hash, e.g. 426f1ce15bf3df70
TNG_IDENTITY_API_KEY=           # x-api-key value
TNG_VERIFIER_DEFINITION_ID=     # presentation definition id, e.g. emailCredential

# --- Proof Fabric Protocol (proof of transaction + verification) ---
PROOF_API_BASE_URL=https://fea-crypto.emergent.host
PROOF_API_KEY=                  # X-API-Key value (pfp_sandbox_...)

# --- Access gate (optional) ---
# Set this on a public deployment to require a password before the app + APIs
# are usable. Leave unset locally to keep the gate OFF.
APP_PASSWORD=
